{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "private-website-rupelxyz",
  "compatibility_date": "2026-06-24",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "bun install && bun run build"
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
